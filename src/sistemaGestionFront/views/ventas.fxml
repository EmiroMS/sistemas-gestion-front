<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="sistemaGestionFront.controllers.VentaController">

    <!-- ================= TOP ================= -->
    <top>

        <VBox spacing="12"
              style="-fx-padding: 15;">

            <Label text="Registro de Venta"
                   style="-fx-font-size:20;
                          -fx-font-weight:bold;"/>

            <!-- CLIENTE -->
            <VBox spacing="5">

                <HBox spacing="10"
                      alignment="CENTER_LEFT">

                    <Label text="Cliente:"
                           style="-fx-font-weight:bold;"/>

                    <TextField fx:id="txtCliente"
                               promptText="Escriba o seleccione cliente"
                               prefWidth="320"
                               prefHeight="35"/>

                </HBox>

                <!-- LISTA AUTOCOMPLETE -->
                <ListView fx:id="listaClientes"
                          prefWidth="320"
                          prefHeight="120"
                          visible="false"/>

            </VBox>


            <!-- PRODUCTOS -->
            <HBox spacing="10"
                  alignment="CENTER_LEFT">

                <ComboBox fx:id="comboProductos"
                          promptText="Seleccione producto"
                          prefWidth="260"
                          prefHeight="35"/>

                <TextField fx:id="txtCantidad"
                           promptText="Cantidad"
                           prefWidth="120"
                           prefHeight="35"/>

                <Button text="Agregar"
                        onAction="#agregarProducto"
                        prefHeight="35"
                        style="-fx-background-color:#2980b9;
                               -fx-text-fill:white;
                               -fx-font-weight:bold;"/>

            </HBox>

        </VBox>

    </top>


    <!-- ================= TABLE ================= -->
    <center>

        <TableView fx:id="tablaVenta"
                   editable="true">

            <columns>

                <TableColumn text="Producto"
                             fx:id="colProducto"
                             prefWidth="300"/>

                <TableColumn text="Cantidad"
                             fx:id="colCantidad"
                             prefWidth="100"/>

                <TableColumn text="Precio Unitario"
                             fx:id="colPrecio"
                             prefWidth="150"/>

                <TableColumn text="Total"
                             fx:id="colTotal"
                             prefWidth="150"/>

                <TableColumn text="Acciones"
                             fx:id="colAcciones"
                             prefWidth="100"/>

            </columns>

        </TableView>

    </center>


    <!-- ================= FOOTER ================= -->
    <bottom>

        <HBox spacing="20"
              alignment="CENTER_RIGHT"
              style="-fx-padding:15;
                     -fx-background-color:#ecf0f1;">

            <Label text="TOTAL:"
                   style="-fx-font-size:18;
                          -fx-font-weight:bold;"/>

            <Label fx:id="lblTotal"
                   text="0.0"
                   style="-fx-font-size:22;
                          -fx-text-fill:#27ae60;
                          -fx-font-weight:bold;"/>

            <Button text="Confirmar Venta"
                    onAction="#confirmarVenta"
                    prefHeight="40"
                    style="-fx-background-color:#27ae60;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;
                           -fx-padding:8 25;"/>

        </HBox>

    </bottom>

</BorderPane>